{\pard\s2\f1\fs24\b\cf4\sb200\sa120 6.3 Guardar / Actualizar Informe\par}

{\pard\cbpat5\li360\ri360\sa80\sb80
{\f2\fs18\cf7
-- Crear nuevo:\line
POST /api/reports\line
Authorization: Bearer <token>\line
Content-Type: application/json\line
\{\line
  "title": "...",\line
  "project_id": "uuid",\line
  "content_json": \{...\},\line
  "status": "draft"\line
\}\line
Respuesta 201: \{ "id": "uuid", ... \}\line
\line
-- Actualizar existente:\line
PUT /api/reports/\{id\}\line
Authorization: Bearer <token>\line
\{\line
  "title": "...",\line
  "content_json": \{...\},\line
  "status": "in_review"\line
\}\line
Respuesta 200: \{ recoge campos actualizados \}\line
El campo version_number se autoincrementa en el backend.\par
}
}

{\pard\s2\f1\fs24\b\cf4\sb200\sa120 6.4 Eliminar (soft delete)\par}

{\pard\cbpat5\li360\ri360\sa80\sb80
{\f2\fs18\cf7
DELETE /api/reports/\{id\}\line
Authorization: Bearer <token>\line
\line
Backend:\line
  SET deleted_at = NOW() WHERE id = \{id\}\line
  INSERT INTO auth_audit_logs (event_action, username, detail, success)\line
    VALUES ('report_deleted', \{username\}, \{report.title\}, true)\line
\line
Respuesta 200: \{ "message": "Informe eliminado correctamente" \}\line
Errores:\line
  403: sin permisos (solo admin puede eliminar cualquier informe;\line
       operator solo puede eliminar los propios en estado draft)\line
  404: no encontrado\par
}
}

{\pard\s2\f1\fs24\b\cf4\sb200\sa120 6.5 Enviar informe a usuario\par}

{\pard\cbpat5\li360\ri360\sa80\sb80
