{\pard\s1\f1\fs28\b\cf3\sb400\sa200 5. MODELO DE DATOS: EXTENSI\'d3N DEL ESQUEMA\par}

{\pard\s2\f1\fs24\b\cf4\sb200\sa120 5.1 Extender Tabla \f2 reports\f1{} existente\par}

{\pard\f3\fs22\sa80
La tabla \f2 reports\f3{} existente en \f2 db_scripts/01_init.sql\f3{} tiene los campos b\'e1sicos. Se extiende con las siguientes columnas mediante migraci\'f3n:\par}

{\pard\cbpat5\li360\ri360\sa100\sb80
{\f2\fs18\cf7
-- Archivo de migraci\'f3n: db_scripts/05_reports_admin.sql\line
\line
-- Extensi\'f3n de la tabla reports existente\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    created_by UUID REFERENCES auth_users(id) ON DELETE SET NULL;\line
\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    reviewed_by UUID REFERENCES auth_users(id) ON DELETE SET NULL;\line
\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    reviewed_at TIMESTAMPTZ;\line
\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    deleted_at TIMESTAMPTZ;              -- soft delete\line
\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    version_number INTEGER NOT NULL DEFAULT 1;\line
\line
ALTER TABLE reports ADD COLUMN IF NOT EXISTS\line
    last_modified_by UUID REFERENCES auth_users(id) ON DELETE SET NULL;\line
\line
-- Tabla para env\'edo de informes entre usuarios\line
CREATE TABLE IF NOT EXISTS report_shares (\line
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\line
    report_id UUID NOT NULL REFERENCES reports(id) ON DELETE CASCADE,\line
    sent_by UUID NOT NULL REFERENCES auth_users(id) ON DELETE CASCADE,\line
    sent_to UUID NOT NULL REFERENCES auth_users(id) ON DELETE CASCADE,\line
    message TEXT,\line
    sent_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\line
    read_at TIMESTAMPTZ\line
);\line
\line
-- Tabla de notificaciones internas\line
CREATE TABLE IF NOT EXISTS notifications (\line
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\line
    user_id UUID NOT NULL REFERENCES auth_users(id) ON DELETE CASCADE,\line
    type VARCHAR(60) NOT NULL,       -- 'report_shared', 'report_reviewed', etc.\line
    payload JSONB NOT NULL DEFAULT '\{\}',\line
    is_read BOOLEAN NOT NULL DEFAULT false,\line
    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\line
);\line
\line
-- \'cdndices de rendimiento\line
CREATE INDEX IF NOT EXISTS idx_reports_created_by ON reports(created_by);\line
CREATE INDEX IF NOT EXISTS idx_reports_created_at ON reports(created_at DESC);\line
CREATE INDEX IF NOT EXISTS idx_reports_status ON reports(status);\line
CREATE INDEX IF NOT EXISTS idx_reports_deleted_at ON reports(deleted_at) WHERE deleted_at IS NULL;\line
CREATE INDEX IF NOT EXISTS idx_report_shares_sent_to ON report_shares(sent_to);\line
CREATE INDEX IF NOT EXISTS idx_notifications_user_id ON notifications(user_id, is_read);\par
}
}

