{\pard\cbpat5\li360\ri360\sa80\sb80
{\f2\fs18\cf7
// --- NUEVOS ESTADOS en App.jsx ---\line
const [showReportsAdmin, setShowReportsAdmin] = useState(false);\line
const [showReadOnly, setShowReadOnly] = useState(false);\line
const [readOnlyReport, setReadOnlyReport] = useState(null);\line
\line
// Handler: abrir modal de administraci\'f3n\line
const handleOpenReportsAdmin = () => setShowReportsAdmin(true);\line
\line
// Handler: abrir en modo lectura (llamado desde ReportsAdminModal)\line
const handleOpenReadOnly = (reportData) => \{\line
  setReadOnlyReport(reportData);\line
  setShowReportsAdmin(false);\line
  setShowReadOnly(true);\line
\};\line
\line
// Handler: abrir en modo edici\'f3n\line
const handleOpenEdit = (reportId, contentJson) => \{\line
  useEditorStore.getState().loadDocument(contentJson);\line
  useEditorStore.getState().setCurrentReportId(reportId);\line
  setShowReportsAdmin(false);\line
\};\line
\line
// En el JSX de App.jsx, agregar los modales:\line
\{\showReportsAdmin && (\line
  <ReportsAdminModal\line
    onClose=\{() => setShowReportsAdmin(false)\}\line
    onOpenRead=\{handleOpenReadOnly\}\line
    onOpenEdit=\{handleOpenEdit\}\line
  />\line
)\}\line
\{\showReadOnly && (\line
  <ReadOnlyViewer\line
    report=\{readOnlyReport\}\line
    onClose=\{() => setShowReadOnly(false)\}\line
  />\line
)\}\par
}
}

{\pard\s2\f1\fs24\b\cf4\sb200\sa120 7.3 ReportsAdminModal.jsx \endash{} estructura interna\par}

{\pard\cbpat5\li360\ri360\sa80\sb80
{\f2\fs18\cf7
// Hooks internos:\line
const [filters, setFilters] = useState(\{\line
  dateFrom: '', dateTo: '',\line
  createdBy: '', reviewedBy: '',\line
  status: 'all', projectId: 'all', title: ''\line
\});\line
const [reports, setReports] = useState([]);\line
const [total, setTotal] = useState(0);\line
const [page, setPage] = useState(1);\line
const [sortBy, setSortBy] = useState('created_at');\line
const [sortDir, setSortDir] = useState('desc');\line
const [loading, setLoading] = useState(false);\line
const [selected, setSelected] = useState(null);  // informe seleccionado\line
const [projects, setProjects] = useState([]);     // lista de proyectos\line
\line
// Carga initial y cuando cambian filtros:\line
useEffect(() => \{ fetchReports(); \}, [filters, page, sortBy, sortDir]);\line
\line
const fetchReports = async () => \{\line
  setLoading(true);\line
  const params = new URLSearchParams(\{\line
    ...filters, page, page_size: 20,\line
    sort_by: sortBy, sort_dir: sortDir\line
  \}).toString();\line
  const res = await fetch(\`/api/reports?\$\{params\}\`, \{\line
    headers: \{ Authorization: \`Bearer \$\{getToken()\}\` \}\line
  \});\line
  const data = await res.json();\line
  setReports(data.data);\line
  setTotal(data.total);\line
  setLoading(false);\line
\};\par
}
}

